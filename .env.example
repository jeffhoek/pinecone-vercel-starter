OPENAI_API_KEY=

# Retrieve the following from the Pinecone Console.

# Navigate to API Keys under your Project to retrieve the API key
PINECONE_API_KEY=
PINECONE_CLOUD=
PINECONE_REGION=

# Navigate to Indexes under your Project to retrieve the Index name
PINECONE_INDEX=

# Google Service Account for accessing private Google Docs
# Create a service account in Google Cloud Console, download the JSON key,
# and paste the entire JSON content as a single line (minified) here.
# Share your Google Docs with the service account email (found in the JSON key).
GOOGLE_SERVICE_ACCOUNT_KEY=

# NextAuth Configuration for Authentication
# At least one auth option (APP_PASSWORD or Google OAuth) must be configured.

# Your application URL (for local dev use http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000

# Generate a random secret with: openssl rand -base64 32
NEXTAUTH_SECRET=

# --- Auth Option A: Passphrase (simple, no external accounts needed) ---
# Set a shared passphrase. Anyone with it can log in.
# Good for self-hosted / single-user / small team use.
# APP_PASSWORD=

# --- Auth Option B: Google OAuth (see GOOGLE_OAUTH_SETUP.md) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: Comma-separated list of allowed email addresses (Google OAuth only)
# Leave empty to allow all Google users
# ALLOWED_EMAILS=

# Testing: Bypass authentication (DO NOT use in production!)
# Set to 'true' to disable auth for Playwright tests
# Default: false (auth required)
# BYPASS_AUTH=true

# Admin Panel Visibility
# Set to 'true' to show the admin panel (dataset management, clear index, splitting options)
# Set to 'false' to hide it in production
# Default: true (shown)
NEXT_PUBLIC_SHOW_ADMIN_PANEL=true